<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>dirx</AssemblyName>
    <RootNamespace>DirX</RootNamespace>
  </PropertyGroup>

  <Target Name="CopyBuildOutputToTools" AfterTargets="Build">
    <MakeDir Directories="e:\tools" />
    <ItemGroup>
      <BuildOutputFiles Include="$(TargetDir)$(TargetName).*" />
    </ItemGroup>
    <Copy SourceFiles="@(BuildOutputFiles)" DestinationFolder="e:\tools" SkipUnchangedFiles="true" />
  </Target>
</Project>